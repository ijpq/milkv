# Makefile for Hardware Encoding Test

# Cross-compilation toolchain (update if needed)
CROSS_COMPILE ?= aarch64-linux-gnu-
CC = $(CROSS_COMPILE)gcc

# SDK paths (on Milk-V Duo S board)
SDK_INC = /mnt/system/include
SDK_LIB = /mnt/system/lib

# Compiler flags
CFLAGS  = -Wall -O2
LDFLAGS = 

# Test without SDK (just system checks)
test_hw_encode_nosdk: test_hw_encode.c
	$(CC) $(CFLAGS) -o test_hw_encode_nosdk test_hw_encode.c
	@echo ""
	@echo "Built test_hw_encode_nosdk (no SDK dependencies)"
	@echo "This will check system status but cannot test actual encoding"

# Test with SDK (full hardware test)
test_hw_encode: test_hw_encode.c
	@if [ ! -d "$(SDK_INC)" ]; then \
		echo "ERROR: SDK headers not found at $(SDK_INC)"; \
		echo "This must be compiled ON the Milk-V Duo S board"; \
		exit 1; \
	fi
	$(CC) $(CFLAGS) -DHAS_CVI_SDK \
		-I$(SDK_INC) \
		-L$(SDK_LIB) \
		-o test_hw_encode test_hw_encode.c \
		-lcvi_common -lcvi_sys -lcvi_vi -lcvi_vpss -lcvi_venc \
		-lpthread -lm
	@echo ""
	@echo "Built test_hw_encode (with SDK)"
	@echo "This can test actual hardware encoding"

clean:
	rm -f test_hw_encode test_hw_encode_nosdk

.PHONY: clean test_hw_encode_nosdk
